{
  "manifest_version": 3,
  "name": "Cookies Eater 2",
  "version": "1.1.0",
  "description": "Summarize cookies and terms using Gemini",
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html"
  },
  "icons" : {
    "16" : "icon16.png",
    "32" : "icon32.png",
    "48" : "icon48.png",
    "128" : "icon128.png"
  }
}
