{
  "manifest_version": 3,
  "name": "Cookies Eater",
  "version": "1.0.0",
  "description": "Summarize cookies and terms using Gemini",
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.ts"]
    }
  ],
  "action": {
    "default_popup": "index.html"
  },
  "icons" : {
    "32" : "icon32.png"
  }
}

